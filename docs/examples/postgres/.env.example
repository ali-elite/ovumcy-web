# Set exactly one secret source before first start. SECRET_KEY takes precedence if both are set.
TZ=UTC
DEFAULT_LANGUAGE=en
SECRET_KEY=
# SECRET_KEY_FILE=/run/secrets/ovumcy_secret_key
POSTGRES_DB=ovumcy
POSTGRES_USER=ovumcy
POSTGRES_PASSWORD=replace_with_a_long_random_password
COOKIE_SECURE=false
# Optional OIDC sign-in for existing local accounts only.
# Requires HTTPS plus COOKIE_SECURE=true when exposed through a public HTTPS entrypoint.
# OIDC_ISSUER_URL=https://id.example.com
# OIDC_CLIENT_ID=ovumcy
# OIDC_CLIENT_SECRET=replace_with_a_client_secret
# OIDC_REDIRECT_URL=https://ovumcy.example.com/auth/oidc/callback
# OIDC_AUTO_PROVISION=false
RATE_LIMIT_LOGIN_MAX=8
RATE_LIMIT_LOGIN_WINDOW=15m
RATE_LIMIT_FORGOT_PASSWORD_MAX=8
RATE_LIMIT_FORGOT_PASSWORD_WINDOW=1h
RATE_LIMIT_API_MAX=300
RATE_LIMIT_API_WINDOW=1m
